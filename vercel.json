{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "services",
  "rewrites": [
    {
      "source": "/account",
      "destination": "/account.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "framework": "vite",
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "maxDuration": 30
    }
  }
}
